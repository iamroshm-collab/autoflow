# Database URL - PostgreSQL
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/new-garage-app"

# Shop Code - Can be customized for different shop locations
NEXT_PUBLIC_SHOP_CODE="AL"

# ── IP camera attendance (Node.js, no Python required) ──────────────────────

# Full RTSP URL of the IP camera placed at the attendance zone.
# When set, employees see a live camera feed on their mobile and the server
# captures the frame server-side when they tap "Mark IN/OUT".
# Leave blank to fall back to browser selfie mode.
# Example: rtsp://admin:password@192.168.1.100:554/stream1
RTSP_CAMERA_URL=""

# Directory where captured attendance frames are saved.
# Defaults to: <project_root>/public/uploads/attendance-captures
# ATTENDANCE_CAPTURES_DIR="C:/absolute/path/to/captures"

# ── Client-side face verification (face-api.js, runs in mobile browser) ──────

# Public URL where face-api.js model files are served.
# The models must be placed in public/models/faceapi/.
NEXT_PUBLIC_FACE_API_MODEL_URL="/models/faceapi"

# Euclidean distance threshold for face matching (0–1, lower = stricter).
# 0.55 is a good starting point; tighten to 0.50 for stricter matching.
NEXT_PUBLIC_FACE_API_DISTANCE_THRESHOLD="0.55"

# Maximum distance accepted server-side (mirrors the client threshold).
ATTENDANCE_FACE_API_MAX_DISTANCE="0.55"

# Admin bootstrap (developer-only setup flow)
# Keep disabled by default. Enable only during controlled setup windows.
ADMIN_BOOTSTRAP_ENABLED="false"
ADMIN_BOOTSTRAP_ALLOW_IN_PRODUCTION="false"
ADMIN_BOOTSTRAP_KEY="YOUR_SECURE_BOOTSTRAP_KEY"

# MSG91 WhatsApp OTP configuration
MSG91_AUTH_KEY=""
MSG91_WHATSAPP_OTP_ENDPOINT="https://control.msg91.com/api/v5/whatsapp/whatsapp-outbound-message/"
MSG91_WHATSAPP_SENDER=""
MSG91_WHATSAPP_TEMPLATE_ID=""
WHATSAPP_OTP_TTL_MINUTES="5"

# Optional app base URL
APP_BASE_URL="http://localhost:3000"

# Multi-frame verifier settings
VERIFY_TOTAL_FRAMES=5
VERIFY_REQUIRED_VOTES=3
VERIFY_FRAME_INTERVAL_MS=200
VERIFY_MAX_ATTEMPTS=3

# Absence scheduler defaults
ABSENCE_CHECK_HOUR=12
ABSENCE_CHECK_MINUTE=0
ABSENCE_HOURS_AFTER_START=3

# Default shift times
DEFAULT_SHIFT_START=09:00
DEFAULT_SHIFT_END=18:00
DEFAULT_SHIFT_GRACE_MINS=10
DEFAULT_SHIFT_OVERTIME_MINS=30

# Correction token TTL (ms)
CORRECTION_TOKEN_TTL_MS=300000

# Secret for cron/automated absence-check endpoint (set to a random value on deploy)
CRON_SECRET="replace-with-secure-random"

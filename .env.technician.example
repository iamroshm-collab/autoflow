# ===========================================
# Environment Variables for Technician System
# ===========================================

# Database Connection
DATABASE_URL="postgresql://username:password@localhost:5432/garage_database"

# Optional app base URL
APP_BASE_URL="http://localhost:3000"

# Server URL
# For local development:
# NEXT_PUBLIC_SERVER_URL="http://localhost:3000"

# For production with Tailscale (replace with your actual Tailscale IP):
NEXT_PUBLIC_SERVER_URL="http://100.87.123.45:3000"

# ===========================================
# Optional: Other environment variables
# ===========================================

# Node Environment
NODE_ENV="production"

# Port (if different from default 3000)
# PORT=3000
